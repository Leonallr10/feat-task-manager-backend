{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@task-manager/auth": ["libs/src/lib/auth"],
      "@task-manager/models": ["libs/src/lib/models"],
      "@task-manager/data-access": ["libs/src/lib/data-access"],
      "@task-manager/tasks": ["libs/src/lib/tasks"],
      "@task-manager/users": ["libs/src/lib/users"],
      "@task-manager/analytics": ["libs/src/lib/analytics"],
      "@task-manager/utils": ["libs/src/lib/utils"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
